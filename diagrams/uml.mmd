classDiagram

class Owner{
    +name
    +available_time
    +add_pet()
    +get_all_tasks()
}

class Pet{
    +name
    +species
    +age
    +tasks
    +add_task()
    +get_tasks()
}

class Task{
    +description
    +duration
    +priority
    +completed
    +mark_complete()
}

class Scheduler{
    +sort_tasks()
    +filter_tasks()
    +generate_schedule()
}

Owner "1" --> "*" Pet
Pet "1" --> "*" Task
Scheduler --> Owner
